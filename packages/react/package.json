{
  "name": "@opdicom/react",
  "version": "0.1.0",
  "description": "React wrapper for the <opdicom-viewer> DICOM viewer Web Component.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    }
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --clean --external react",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@opdicom/viewer": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0"
  },
  "keywords": ["dicom", "viewer", "react", "web-component"]
}
