{
  "name": "opdicom-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "OpDICOM — modern, zero-footprint, framework-agnostic DICOM web viewer & high-performance parser",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @opdicom/demo dev",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --audit-level moderate",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
